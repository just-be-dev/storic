{
  "name": "storic",
  "version": "0.0.0",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "private": true,
  "scripts": {
    "build": "cd packages/core && bun run build && cd ../cloudflare && bun run build",
    "build:core": "cd packages/core && bun run build",
    "build:cloudflare": "cd packages/cloudflare && bun run build",
    "check": "cd packages/core && bun run check && cd ../cloudflare && bun run check",
    "check:core": "cd packages/core && bun run check",
    "check:cloudflare": "cd packages/cloudflare && bun run check",
    "test": "cd packages/core && bun test && cd ../cloudflare && bun test",
    "test:core": "cd packages/core && bun test",
    "test:cloudflare": "cd packages/cloudflare && bun test",
    "example": "bun examples/example.ts"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.29",
    "@effect/sql-sqlite-bun": "4.0.0-beta.29",
    "effect": "4.0.0-beta.29"
  }
}
